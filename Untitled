{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node", "@playwright/test"],

    "resolveJsonModule": true,
    "allowJs": true,

    "noEmit": true
  },

  "include": [
    "tests",
    "pages",
    "**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}